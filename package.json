{
  "name": "patchproof-workspace",
  "private": true,
  "version": "0.1.0-alpha.1",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "corepack pnpm -r --if-present build",
    "clean": "corepack pnpm -r --if-present clean",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:docs": "node scripts/check-docs.mjs",
    "check:version": "node scripts/check-version.mjs",
    "version:sync": "node scripts/sync-version.mjs",
    "check": "corepack pnpm check:version && corepack pnpm typecheck && corepack pnpm lint && corepack pnpm format && corepack pnpm test && corepack pnpm check:docs && corepack pnpm build",
    "pack:cli": "corepack pnpm --filter @jayadityavetsa/patchproof pack --pack-destination artifacts",
    "acceptance:package": "node scripts/package-acceptance.mjs",
    "release:verify": "node scripts/release-verify.mjs",
    "bundle:action": "corepack pnpm --filter @patchproof/github-action build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^4.1.9"
  }
}
