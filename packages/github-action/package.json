{
  "name": "@patchproof/github-action",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --minify",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@actions/artifact": "^2.3.2",
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@patchproof/core": "workspace:*",
    "@patchproof/git": "workspace:*",
    "@patchproof/reporters": "workspace:*"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.3"
  }
}
