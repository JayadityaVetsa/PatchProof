{
  "name": "@jayadityavetsa/patchproof",
  "version": "0.1.0-alpha.3",
  "description": "Prove that changed regression tests distinguish a patch from its base revision.",
  "keywords": [
    "testing",
    "regression-test",
    "regression-testing",
    "test-before-fix",
    "test-effectiveness",
    "counterfactual-testing",
    "continuous-integration",
    "developer-tools",
    "git",
    "github-actions",
    "pytest",
    "jest",
    "vitest"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JayadityaVetsa/PatchProof.git"
  },
  "homepage": "https://jayadityavetsa.github.io/PatchProof/",
  "bugs": {
    "url": "https://github.com/JayadityaVetsa/PatchProof/issues"
  },
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "patchproof": "dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepack": "node scripts/prepare-package.mjs",
    "postpack": "node scripts/cleanup-package.mjs",
    "build": "tsup --config tsup.config.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@patchproof/core": "workspace:*",
    "@patchproof/git": "workspace:*",
    "@patchproof/reporters": "workspace:*",
    "commander": "^14.0.0",
    "tsup": "^8.5.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
